# ─────────────────────────────────────────────────────────────────────────────
# Migration Agent — backend environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Source database (legacy system). Any PostgreSQL connection string.
# Percent-encode special characters in the password (e.g. '@' -> '%40').
ABASE_DATABASE_URL=postgresql://user:password@host:5432/postgres

# Target database (new system). Any PostgreSQL connection string.
GDS_DATABASE_URL=postgresql://user:password@host:5432/postgres

# Google Gemini API key (billing recommended — the free tier 503s under load).
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# CORS origin for the HITL console (optional; defaults are permissive in dev).
FRONTEND_URL=http://localhost:3000

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
